#include "main.h"

/**
 * _isalpha - a function that checks for alphabetic character
 * @c: single letter input
 * Return: 1 if int c is a letter, 0 if otherwise
 */

int _isalpha(int c)

{
	if (c >= 'a' && c <= 'z')
		return (1);
	else if (c >= 'A' && c <= 'Z')
		return (1);
	else
		return (0);
}

