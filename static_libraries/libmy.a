#include "main.h"

/**
 * _memset - please i want to use the real thing
 * @s: pointer char 1
 * @b: char 2
 * @n: unsigned int
 * Return: ese
 */

char *_memset(char *s, char b, unsigned int n)
{
	while (n--)
	{
		*(s + n) = b;
	}
	return (s);
}

